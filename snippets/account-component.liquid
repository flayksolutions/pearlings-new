{% doc %}
  @param {string} [display_by] - Display by icon or text
  @param {string} [box_size] - Box size
  @param {string} [external_classes] - External classes
  @param {string} [account_button_classes] - Account button classes
  @param {boolean} [enable_tooltip] - Enable tooltip

  Remain box_size for compatibility with old code. It works similar to external_classes.

  @example
  {% render 'account-component', display_by: 'icon', box_size: 'm:w-full', external_classes: 'm-header__account-icon', enable_tooltip: true %}
{% enddoc %}

{% liquid
  assign account_text = 'layout.customer.log_in' | t

  if customer
    assign account_text = 'layout.customer.account' | t
  endif

  assign display_by = display_by | default: 'icon'

  assign classes = 'm-account-component m:block'
  if box_size != blank
    assign classes = classes | append: ' ' | append: box_size
  endif

  if external_classes != blank
    assign classes = classes | append: ' ' | append: external_classes
  endif
%}
{% if shop.customer_accounts_enabled %}
  <m-account-component class="{{ classes | strip | strip_newlines  }}">
    <shopify-account class="m:block" menu="{{ settings.customer_account_menu }}">
      {% if customer %}
        <div class="account-button__fallback no-empty" aria-label="{{ 'layout.customer.account' | t }}"></div>
      {% else %}
        <span
          slot="signed-out-avatar"
          aria-hidden="true"
          aria-label="{{ 'layout.customer.account' | t  }}"
          class="account-button m:display-flex m:justify-center m:items-center{% if account_button_classes != blank %} {{ account_button_classes }}{% endif %}"
        >
          {% if display_by == 'icon' %}
            {% if enable_tooltip %}
              <span class="m-tooltip m:block m-tooltip--bottom m-tooltip--style-2">
                <svg
                  class="m-svg-icon--medium"
                  fill="currentColor"
                  stroke="currentColor"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 448 512"
                >
                  <path d="M313.6 304c-28.7 0-42.5 16-89.6 16-47.1 0-60.8-16-89.6-16C60.2 304 0 364.2 0 438.4V464c0 26.5 21.5 48 48 48h352c26.5 0 48-21.5 48-48v-25.6c0-74.2-60.2-134.4-134.4-134.4zM400 464H48v-25.6c0-47.6 38.8-86.4 86.4-86.4 14.6 0 38.3 16 89.6 16 51.7 0 74.9-16 89.6-16 47.6 0 86.4 38.8 86.4 86.4V464zM224 288c79.5 0 144-64.5 144-144S303.5 0 224 0 80 64.5 80 144s64.5 144 144 144zm0-240c52.9 0 96 43.1 96 96s-43.1 96-96 96-96-43.1-96-96 43.1-96 96-96z"/>
                </svg>
                <span class="m-tooltip__content">{{ account_text }}</span>
              </span>
            {% else %}
              <svg
                class="m-svg-icon--medium"
                fill="currentColor"
                stroke="currentColor"
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 448 512"
              >
                <path d="M313.6 304c-28.7 0-42.5 16-89.6 16-47.1 0-60.8-16-89.6-16C60.2 304 0 364.2 0 438.4V464c0 26.5 21.5 48 48 48h352c26.5 0 48-21.5 48-48v-25.6c0-74.2-60.2-134.4-134.4-134.4zM400 464H48v-25.6c0-47.6 38.8-86.4 86.4-86.4 14.6 0 38.3 16 89.6 16 51.7 0 74.9-16 89.6-16 47.6 0 86.4 38.8 86.4 86.4V464zM224 288c79.5 0 144-64.5 144-144S303.5 0 224 0 80 64.5 80 144s64.5 144 144 144zm0-240c52.9 0 96 43.1 96 96s-43.1 96-96 96-96-43.1-96-96 43.1-96 96-96z"/>
              </svg>
            {% endif %}
          {% else %}
            {{ account_text }}
          {% endif %}
        </span>
      {% endif %}
    </shopify-account>
  </m-account-component>
{% endif %}
