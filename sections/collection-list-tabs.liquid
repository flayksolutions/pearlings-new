{{ 'component-collection-card.css' | asset_url | stylesheet_tag }}
{{ 'tabs.css' | asset_url | stylesheet_tag }}
{{ 'product-tabs.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-tabs.js' | asset_url }}" defer="defer"></script>
{%- liquid
  assign tab_header = section.settings.tab_header
  assign items_per_row = section.settings.items_per_row
  assign card_style = section.settings.card_style
  assign card_heading_size = section.settings.card_heading_size
  assign text_alignment = section.settings.text_alignment
  assign show_product_count = section.settings.show_product_count
  assign hover_effect = section.settings.hover_effect
  assign image_rounded = section.settings.image_rounded

  assign enable_slider = false
  assign mobile_disable_slider = section.settings.mobile_disable_slider
  if section.settings.enable_slider
    assign enable_slider = true
  endif
  assign use_scroll_mobile = section.settings.use_scroll_mobile

  assign animation_effect = settings.animations
  assign animated = false
  if animation_effect != 'none'
    assign animated = true
    if section.settings.animations != 'inherit'
      assign animation_effect = section.settings.animations
    endif
  endif

  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif

  assign classes = 'm-section m-product-tabs m:block'
  if section.settings.custom_class != blank
    assign classes = classes | append: ' ' | append: section.settings.custom_class
  endif
  assign classes = classes | append: ' m-product-tabs--' | append: tab_header | append: ' m-gradient' | append: ' m-color-' | append: section.settings.color_scheme
-%}

{%- capture dropdown -%}
  {% if section.blocks.size > 0 %}
    <m-select-component data-tab-header="{{ tab_header }}">
      <select
        name="country_code"
        class="js-selectNative"
        data-tab-select
      >
        {% for block in section.blocks %}
          {%- liquid
            assign tab_name = block.settings.title
            if tab_name == blank
              assign tab_name = 'Tab ' | append: forloop.index
            endif
          -%}
          <option
            value="{{ forloop.index0 }}"
            {% if forloop.index0 == 0 %}
              selected="selected"
            {% endif %}
          >
            {{ tab_name }}
          </option>
        {%- endfor -%}
      </select>
      <div
        class="m-select-custom m-select-custom--custom-width m-select-custom--plain js-selectCustom {{ section.settings.tab_heading_size | default: 'h3' }}"
        aria-hidden="true"
      >
        <div class="m-select-custom--trigger">
          <span class="m-select-custom--trigger-text"></span>
          <span class="m-select-custom--trigger-icon">
            <svg
              fill="currentColor"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 448 512"
            >
              <path d="M441.9 167.3l-19.8-19.8c-4.7-4.7-12.3-4.7-17 0L224 328.2 42.9 147.5c-4.7-4.7-12.3-4.7-17 0L6.1 167.3c-4.7 4.7-4.7 12.3 0 17l209.4 209.4c4.7 4.7 12.3 4.7 17 0l209.4-209.4c4.7-4.7 4.7-12.3 0-17z" />
            </svg>
          </span>
        </div>
        <div class="m-select-custom--options">
          {% for block in section.blocks %}
            {%- liquid
              assign tab_name = block.settings.title
              if tab_name == blank
                assign tab_name = 'Tab ' | append: forloop.index
              endif
            -%}
            <div class="m-select-custom--option" data-value="{{ forloop.index0 }}">
              {{ tab_name }}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </m-select-component>
  {% endif %}
{%- endcapture -%}

<style>
  #m-section--{{ section.id }} {
    --column-gap: {{ section.settings.item_gap }}px;
    --column-gap-mobile: {{ section.settings.item_gap_mobile }}px;
    --row-gap: {{ section.settings.item_gap | plus: 10 }}px;
    --items: {{ items_per_row }};
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>
<section
  id="m-section--{{ section.id }}"
  class="{{ classes }}"
>
  <m-product-tabs
    id="{{ section.id }}"
    data-section-type="collection-list-tabs"
    data-enable-slider="{{ enable_slider }}"
    data-mobile-disable-slider="{{ section.settings.mobile_disable_slider }}"
    data-button-type="link"
    {% if enable_slider %}
      data-show-pagination="{{ section.settings.show_pagination }}"
      data-show-navigation="{{ section.settings.show_navigation }}"data-items="{{ items_per_row }}"
    {% endif -%}
  >
    <div class="{{ container }} m-section-my m-section-py">
      <div class="m-section__header m:text-{{ section.settings.header_alignment }}">
        {% if section.settings.subheading != blank %}
          <p class="m-section__subheading m:w-full{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
            {{ section.settings.subheading }}
          </p>
        {% endif %}

        {% if tab_header == 'horizontal' %}
          {% if section.settings.heading != blank %}
            <h2 class="m-section__heading {{ section.settings.heading_size | default: 'h3' }}{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
              {{ section.settings.heading }}
            </h2>
          {% endif %}
        {% else %}
          <div class="m-section__heading {% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
            {% if section.settings.heading != blank %}
              <h2 class="{{ section.settings.heading_size | default: 'h3' }}">{{ section.settings.heading }}&nbsp;</h2>
            {% endif %}
            {{ dropdown }}
          </div>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="m-section__description m:w-full{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
            {{ section.settings.description }}
          </div>
        {% endif %}

        {% if tab_header == 'horizontal' and section.blocks.size > 0 %}
          <div class="m-section__tabs{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}">
            <div class="m-tabs__wrapper">
              {% for block in section.blocks %}
                {%- liquid
                  assign tab_name = block.settings.title
                  if tab_name == blank
                    assign tab_name = 'Tab ' | append: forloop.index
                  endif
                -%}
                <a
                  class="m-tab-header {{ section.settings.tab_heading_size | default: 'h5' }}"
                  href="#collection-list-tabs-{{ block.id }}"
                  data-index="{{ forloop.index0 }}"
                >
                  {{- tab_name -}}
                </a>
              {% endfor %}
            </div>
            {{ dropdown }}
          </div>
        {% endif %}
      </div>

      {% if section.blocks.size > 0 %}
        <div class="m-product-tabs__content">
          {% for block in section.blocks %}
            <div
              id="collection-list-tabs-{{ block.id }}"
              class="m-tab-content m-swiper-overflow"
              {{ block.shopify_attributes }}
              data-index="{{ forloop.index0 }}"
              data-enable-slide="{{ enable_slider }}"
            >
              <div class="m-product-list m-slider-control-hover-inside m-mixed-layout {% if mobile_disable_slider or enable_slider != true %} m-mixed-layout--mobile-grid{% if use_scroll_mobile %} m-mixed-layout--mobile-scroll{% endif %}{% endif %}">
                <div class="m-mixed-layout__wrapper{% if enable_slider %} swiper-container{% endif %}">
                  <div
                    class="m-mixed-layout__inner m:grid m:grid-2-cols md:m:grid-3-cols lg:m:grid-4-cols xl:m:grid-{{ section.settings.items_per_row }}-cols{% if enable_slider %} swiper-wrapper{% endif %}"
                  >
                    {%- liquid
                      assign tab_has_content = false
                      for i in (1..6)
                        assign col_key = 'collection_' | append: i
                        if block.settings[col_key] != blank
                          assign tab_has_content = true
                          break
                        endif
                      endfor
                    -%}
                    {% if tab_has_content %}
                      {% for i in (1..6) %}
                        {%- assign col_key = 'collection_' | append: i -%}
                        {%- assign img_key = 'image_' | append: i -%}
                        {%- assign coll = collections[block.settings[col_key]] -%}
                        {% if coll != blank %}
                          {% render 'collection-card',
                            section: section,
                            collection: coll,
                            card_style: card_style,
                            heading_size: card_heading_size,
                            text_alignment: text_alignment,
                            show_product_count: show_product_count,
                            enable_slider: enable_slider,
                            image_rounded: image_rounded,
                            hover_effect: hover_effect,
                            image: block.settings[img_key],
                            index: forloop.index,
                            animated: animated,
                            animation_effect: animation_effect
                          %}
                        {% endif %}
                      {% endfor %}
                    {% else %}
                      {% for i in (1..items_per_row) %}
                        <div class="m:column{% if enable_slider %} swiper-slide{% endif %}">
                          <div
                            class="m-collection-card m-collection-card--{{ card_style }}{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}"
                            {% if animated %}
                              data-cascade
                              style="--animation-order: {{ forloop.index }};"
                            {% endif %}
                          >
                            <div class="m-collection-card__inner">
                              <div style="--aspect-ratio: 1/1;">
                                {% capture current %}{% cycle 1, 2, 3, 4, 5, 6 %}{% endcapture %}
                                {{ 'collection-' | append: current | placeholder_svg_tag: 'm-placeholder-svg' }}
                              </div>
                              <div class="m-collection-card__info m:text-{{ text_alignment }}">
                                <a href="#" class="{{ card_heading_size | default: 'h5' }}">
                                  {{ 'homepage.onboarding.collection_title' | t }}
                                </a>
                              </div>
                            </div>
                          </div>
                        </div>
                      {% endfor %}
                    {% endif %}
                  </div>
                </div>
                {% if enable_slider %}
                  {% if section.settings.show_navigation or section.settings.show_pagination %}
                    {% render 'slider-controls',
                      extra_classes: 'm:hidden',
                      absolute: true,
                      container: section.settings.container,
                      show_nav: section.settings.show_navigation,
                      show_pagination: section.settings.show_pagination,
                      nav_class: 'm:hidden'
                    %}
                  {% endif %}
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </m-product-tabs>
</section>

{% schema %}
{
  "name": "Collection list tabs",
  "class": "m-section-collection-list-tabs",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Shop by collection"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h3",
      "options": [
        { "label": "Heading xs", "value": "h6" },
        { "label": "Heading sm", "value": "h5" },
        { "label": "Heading md", "value": "h4" },
        { "label": "Heading lg", "value": "h3" },
        { "label": "Heading xl", "value": "h2" },
        { "label": "Heading 2xl", "value": "h1" }
      ]
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "header_alignment",
      "label": "Text alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "select",
      "id": "container",
      "label": "Container type",
      "default": "container-fluid",
      "options": [
        { "value": "container-fluid", "label": "Default" },
        { "value": "w-full", "label": "Full width" },
        { "value": "container", "label": "Use container box" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "tab_header",
      "label": "Tab header type",
      "default": "horizontal",
      "options": [
        { "value": "horizontal", "label": "Horizontal" },
        { "value": "select", "label": "Title with select" }
      ]
    },
    {
      "type": "select",
      "id": "tab_heading_size",
      "label": "Tab heading size",
      "default": "h5",
      "options": [
        { "label": "Heading xs", "value": "h6" },
        { "label": "Heading sm", "value": "h5" },
        { "label": "Heading md", "value": "h4" },
        { "label": "Heading lg", "value": "h3" },
        { "label": "Heading xl", "value": "h2" },
        { "label": "Heading 2xl", "value": "h1" }
      ]
    },
    {
      "type": "header",
      "content": "Collection card settings"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card style",
      "default": "standard",
      "options": [
        { "value": "standard", "label": "Standard" },
        { "value": "boxed", "label": "Boxed" },
        { "value": "inside", "label": "Content inside" },
        { "value": "inside-2", "label": "Button only" }
      ]
    },
    {
      "type": "select",
      "id": "card_heading_size",
      "label": "Card heading size",
      "default": "h5",
      "options": [
        { "label": "Heading xs", "value": "h6" },
        { "label": "Heading sm", "value": "h5" },
        { "label": "Heading md", "value": "h4" },
        { "label": "Heading lg", "value": "h3" }
      ]
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "hover_effect",
      "label": "Hover effect",
      "default": "scaling-down",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "scaling-down", "label": "Scaling down" },
        { "value": "scaling-up", "label": "Scaling up" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_product_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "image_rounded",
      "label": "Image rounded",
      "default": false
    },
    {
      "type": "header",
      "content": "Grid settings"
    },
    {
      "type": "range",
      "id": "items_per_row",
      "label": "Collections per row",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Column gap",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 30,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Slider settings"
    },
    {
      "type": "checkbox",
      "id": "enable_slider",
      "label": "Enable slider",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_navigation",
      "label": "Show navigation",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show pagination",
      "default": false
    },
    {
      "type": "header",
      "content": "Mobile settings"
    },
    {
      "type": "checkbox",
      "label": "Disable slider",
      "id": "mobile_disable_slider",
      "default": false
    },
    {
      "type": "checkbox",
      "label": "Use horizontal scrollbar",
      "id": "use_scroll_mobile",
      "default": true,
      "info": "Uncheck to display as grid, slider must be disabled"
    },
    {
      "type": "range",
      "id": "item_gap_mobile",
      "label": "Column gap",
      "min": 0,
      "max": 30,
      "step": 2,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Custom Attributes"
    },
    {
      "type": "text",
      "id": "custom_class",
      "label": "Custom classes"
    },
    {
      "type": "header",
      "content": "Animations"
    },
    {
      "type": "select",
      "id": "animations",
      "label": "Visible in the view animation",
      "default": "inherit",
      "options": [
        { "value": "inherit", "label": "Inherit global setting" },
        { "value": "fade-in", "label": "Fade in" },
        { "value": "fade-in-up", "label": "Fade in up" },
        { "value": "fade-in-left", "label": "Fade in left" },
        { "value": "fade-in-right", "label": "Fade in right" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab name"
        },
        {
          "type": "header",
          "content": "Collections (up to 6)"
        },
        {
          "type": "collection",
          "id": "collection_1",
          "label": "Collection 1"
        },
        {
          "type": "image_picker",
          "id": "image_1",
          "label": "Image 1",
          "info": "Leave blank to use collection image"
        },
        {
          "type": "collection",
          "id": "collection_2",
          "label": "Collection 2"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "Image 2",
          "info": "Leave blank to use collection image"
        },
        {
          "type": "collection",
          "id": "collection_3",
          "label": "Collection 3"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "Image 3",
          "info": "Leave blank to use collection image"
        },
        {
          "type": "collection",
          "id": "collection_4",
          "label": "Collection 4"
        },
        {
          "type": "image_picker",
          "id": "image_4",
          "label": "Image 4",
          "info": "Leave blank to use collection image"
        },
        {
          "type": "collection",
          "id": "collection_5",
          "label": "Collection 5"
        },
        {
          "type": "image_picker",
          "id": "image_5",
          "label": "Image 5",
          "info": "Leave blank to use collection image"
        },
        {
          "type": "collection",
          "id": "collection_6",
          "label": "Collection 6"
        },
        {
          "type": "image_picker",
          "id": "image_6",
          "label": "Image 6",
          "info": "Leave blank to use collection image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list tabs",
      "category": "Collection",
      "settings": {
        "heading": "Shop by collection"
      },
      "blocks": [
        {
          "type": "tab",
          "settings": { "title": "Tab 1" }
        },
        {
          "type": "tab",
          "settings": { "title": "Tab 2" }
        }
      ]
    }
  ]
}
{% endschema %}
