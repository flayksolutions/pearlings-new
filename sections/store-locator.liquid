{{ 'store-locator.css' | asset_url | stylesheet_tag }}
{% liquid
  assign animation_effect = settings.animations
  assign animated = false
  if animation_effect != 'none'
    assign animated = true
    if section.settings.animations != 'inherit'
      assign animation_effect = section.settings.animations
    endif
  endif

  assign loading = 'lazy'
  assign fetchpriority = 'low'
  if section.index < 2
    assign loading = 'eager'
    assign fetchpriority = 'high'
  endif

  assign image_width = section.settings.image_width

  assign image = section.settings.image
  assign aspect_ratio = image.aspect_ratio | default: 1

  assign image_classes = 'm-store-locator__image'
  assign content_classes = 'm-store-locator__content m:display-flex m:flex-col m:justify-center'

  case image_width
    when 'large'
      assign image_classes = image_classes | append: ' lg:m:w-8/12 m:w-full'
      assign content_classes = content_classes | append: ' lg:m:w-4/12 m:w-full'
      assign aspect_ratio = image.aspect_ratio | default: 2.333
    when 'medium'
      assign image_classes = image_classes | append: ' lg:m:w-1/2 m:w-full'
      assign content_classes = content_classes | append: ' lg:m:w-1/2 m:w-full'
    when 'small'
      assign image_classes = image_classes | append: ' lg:m:w-4/12 m:w-full'
      assign content_classes = content_classes | append: ' lg:m:w-8/12 m:w-full'
  endcase

  if section.settings.image_position == 'right'
    assign image_classes = image_classes | append: ' lg:order-last'
  endif

  assign item_columns_tablet = section.settings.item_columns | plus: 0 | at_most: 2

  assign color_inherit = false
  if section.settings.color_scheme == section.settings.container_color_scheme
    assign color_inherit = true
  endif
%}
<style>
  #m-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #m-section-{{ section.id }} .m-store-locator__content-inner {
    --column-gap: {{ section.settings.item_column_gap }}px;
    --column-gap-tablet: {{ section.settings.item_column_gap }}px;
    --column-gap-mobile: {{ section.settings.item_column_gap_mobile }}px;
    --row-gap: {{ section.settings.item_row_gap }}px;
    --row-gap-mobile: {{ section.settings.item_row_gap_mobile }}px;
  }
</style>
<section
  id="m-section-{{ section.id }}"
  class="m-section m-store-locator m-store-locator--image-{{ section.settings.image_position }}{% if color_inherit %} color-inherit{% endif %} m-gradient m-color-{{ section.settings.color_scheme }}"
>
  <div class="{{ section.settings.container }} m-section-my m-section-py">
    <div class="m-store-locator__inner m:display-flex m:flex-wrap m-gradient m-color-{{ section.settings.container_color_scheme }}">
      <div class="{{ image_classes }}">
        <div class="m-media m:h-full" style="--aspect-ratio: {{ aspect_ratio }};">
          {% if image == blank %}
            {% liquid
              assign placeholder_svg_tag = 'm-placeholder-svg m-placeholder-svg--no-border m:object-cover m:w-full m:h-full'
            %}
            {% if image_width == 'large' %}
              {% capture current %}{% cycle 1, 2 %}{% endcapture %}
              {{ 'lifestyle-' | append: current | placeholder_svg_tag: placeholder_svg_tag }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: placeholder_svg_tag }}
            {% endif %}
          {% endif %}
          {% if image != blank %}
            <picture class="m-media__wrapper m:block m:w-full m:h-full{% if image == blank %} md:m:hidden{% endif %}">
              {% liquid
                assign image_height = image.width | divided_by: image.aspect_ratio | round
              %}
              {{
                image
                | image_url: width: 2000
                | image_tag:
                  loading: loading,
                  fetchpriority: fetchpriority,
                  width: image.width,
                  height: image_height,
                  widths: '300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000',
                  alt: image.alt
              }}
            </picture>
          {%- endif %}
        </div>
      </div>
      <div class="{{ content_classes }}">
        {% render 'index-section-header', section_settings: section.settings %}
        <div class="m-store-locator__content-inner m:grid m:grid-{{ section.settings.item_columns_mobile }}-cols md:m:grid-{{ item_columns_tablet }}-cols xl:m:grid-{{ section.settings.item_columns }}-cols">
          {% for block in section.blocks %}
            <div
              class="m-store-locator__block m-store-locator__{{ block.type }} m:column {% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}"
              {% if animated %}
                data-cascade
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
              {{ block.shopify_attributes }}
            >
              {% case block.type %}
                {% when 'text' %}
                  <div class="m-richtext m-richtext--small">
                    {% if block.settings.heading != blank %}
                      <h3 class="m-richtext__title {{ block.settings.heading_size }}">{{ block.settings.heading }}</h3>
                    {% endif %}
                    {% if block.settings.text != blank %}
                      <div class="m-richtext__description rte {{ block.settings.text_size | prepend: 'm:' }} m:text-color-subtext">
                        {{ block.settings.text }}
                      </div>
                    {% endif %}
                    {% if block.settings.button_label != blank %}
                      <div class="m-richtext__button">
                        <a
                          href="{{ block.settings.button_link }}"
                          class="m-button {{ block.settings.button_style }} {{ block.settings.button_size }}"
                        >
                          {{- block.settings.button_label -}}
                        </a>
                      </div>
                    {% endif %}
                  </div>
                {% when 'social_media' %}
                  <div class="m-richtext m-richtext--small">
                    {% if block.settings.heading != blank %}
                      <h3 class="m-richtext__title {{ block.settings.heading_size }}">{{ block.settings.heading }}</h3>
                    {% endif %}
                    <div class="m-richtext__social-media m:display-flex">
                      {% render 'social-media-links', extra_classes: 'm:text-color-body', size: 'medium-small' %}
                    </div>
                  </div>
                {% when 'icon_box' %}
                  {% render 'icon-box',
                    block: block,
                    card_style: block.settings.card_style,
                    card_color_scheme: section.settings.container_color_scheme,
                    heading_size: block.settings.heading_size,
                    text_size: block.settings.text_size,
                    content_alignment: 'left',
                    image_max_width: block.settings.image_max_width,
                    section_color_scheme: section.settings.container_color_scheme,
                    hover_effect: block.settings.hover_effect,
                    index: forloop.index
                  %}
              {% endcase %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

